# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
out
*.local
*.tsbuildinfo

# native/audio-engine (napi-rs) — rebuilt by `npm run build:native` /
# postinstall; the compiled binary and generated JS/TS glue don't belong in
# version control, same as `out/` for the main electron-vite build.
native/audio-engine/target
native/*.node
native/**/*.node
native/audio-engine/index.js
native/audio-engine/index.d.ts

# AppStream metainfo.xml (scripts/gen-appstream.mjs) — generated at build
# time so its <release date> always matches when the .deb was actually built.
build/linux/

# Old PyQt app (kept in the editor workspace for reference during the port,
# lives as a sibling directory — not actually nested in this repo, but
# ignored defensively in case it ever ends up copied/symlinked in).
sonar/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
